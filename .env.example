# ──────────────────────────────────────────────────────────
# DataGuard — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy to .env and fill in your credentials
#   cp .env.example .env
#
# Docker Compose automatically loads .env:
#   docker compose up
# ──────────────────────────────────────────────────────────

# ── Slack Alerting ───────────────────────────────────────
# Create a Slack webhook at: https://api.slack.com/messaging/webhooks
DATAGUARD_SLACK_WEBHOOK=
DATAGUARD_SLACK_CHANNEL=#data-quality

# ── Email Alerting ───────────────────────────────────────
# For Gmail: use an App Password (not your regular password)
#   https://support.google.com/accounts/answer/185833
DATAGUARD_SMTP_HOST=smtp.gmail.com
DATAGUARD_SMTP_PORT=587
DATAGUARD_SMTP_USER=
DATAGUARD_SMTP_PASS=
DATAGUARD_FROM_EMAIL=dataguard@example.com
DATAGUARD_ALERT_EMAILS=

# ── Scheduling ───────────────────────────────────────────
# Interval in seconds between scheduled pipeline runs
SCHEDULE_INTERVAL=3600
